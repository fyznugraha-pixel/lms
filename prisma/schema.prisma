generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  passwordHash      String
  role              Role
  isActive          Boolean              @default(true)
  namaLengkap       String?
  absensiKantor     AbsensiKantor[]      @relation("KaryawanAbsensi")
  exportLog         ExportLog[]          @relation("ExportLogUser")
  pengajuanDiproses PengajuanIzin[]      @relation("AdminPengajuan")
  pengajuanIzin     PengajuanIzin[]      @relation("KaryawanPengajuan")
  sesiAbsenDibuat   SesiAbsenKantor[]    @relation("DibuatOlehSesi")
  sesiLogin         SesiLogin[]          @relation("UserSesiLogin")
  todoItem          TodoItem[]           @relation("TodoKaryawan")
  tokenAbsenKantor  TokenAbsenKaryawan[] @relation("KaryawanToken")
  workLog           WorkLog[]            @relation("WorkLogKaryawan")
}

model SesiAbsenKantor {
  id            String               @id @default(uuid())
  tanggal       DateTime             @db.Date
  jenisAbsen    JenisAbsenKantor
  dibuatOlehId  String
  waktuDibuat   DateTime             @default(now())
  status        StatusSesiKantor     @default(AKTIF)
  absensiMasuk  AbsensiKantor[]      @relation("SesiMasuk")
  absensiPulang AbsensiKantor[]      @relation("SesiPulang")
  dibuatOleh    User                 @relation("DibuatOlehSesi", fields: [dibuatOlehId], references: [id])
  tokens        TokenAbsenKaryawan[]
}

model TokenAbsenKaryawan {
  id                String          @id @default(uuid())
  sesiAbsenKantorId String
  karyawanId        String
  token             String          @unique
  expiresAt         DateTime
  isUsed            Boolean         @default(false)
  karyawan          User            @relation("KaryawanToken", fields: [karyawanId], references: [id])
  sesiAbsenKantor   SesiAbsenKantor @relation(fields: [sesiAbsenKantorId], references: [id])

  @@unique([sesiAbsenKantorId, karyawanId])
}

model AbsensiKantor {
  id               String              @id @default(uuid())
  karyawanId       String
  tanggal          DateTime            @db.Date
  sesiMasukId      String?
  sesiPulangId     String?
  waktuAbsenMasuk  DateTime?
  waktuAbsenPulang DateTime?
  status           StatusAbsensiKantor
  durasiKerja      Int?
  isIncomplete     Boolean             @default(false)
  metode           MetodeAbsensiKantor
  karyawan         User                @relation("KaryawanAbsensi", fields: [karyawanId], references: [id])
  sesiMasuk        SesiAbsenKantor?    @relation("SesiMasuk", fields: [sesiMasukId], references: [id])
  sesiPulang       SesiAbsenKantor?    @relation("SesiPulang", fields: [sesiPulangId], references: [id])

  @@unique([karyawanId, tanggal])
}

model PengajuanIzin {
  id              String             @id @default(uuid())
  karyawanId      String
  jenis           JenisPengajuanIzin
  tanggalMulai    DateTime           @db.Date
  tanggalSelesai  DateTime           @db.Date
  alasan          String
  lampiranUrl     String?
  status          StatusPengajuan    @default(PENDING)
  diprosesOlehId  String?
  catatanApproval String?
  adaKonflikAbsen Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  diprosesOleh    User?              @relation("AdminPengajuan", fields: [diprosesOlehId], references: [id])
  karyawan        User               @relation("KaryawanPengajuan", fields: [karyawanId], references: [id])
}

model ExportLog {
  id           String   @id @default(uuid())
  exportedById String
  bulan        Int
  tahun        Int
  createdAt    DateTime @default(now())
  exportedBy   User     @relation("ExportLogUser", fields: [exportedById], references: [id])
}

model SesiLogin {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  deviceInfo       String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  deviceId         String?
  user             User      @relation("UserSesiLogin", fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId])
}

model WorkLog {
  id                String   @id @default(uuid())
  karyawanId        String
  tanggal           DateTime @db.Date
  dikerjakanHariIni String
  rencanaBesok      String
  blocker           String?
  isPrivat          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  adminFeedback     String?
  karyawan          User     @relation("WorkLogKaryawan", fields: [karyawanId], references: [id])

  @@unique([karyawanId, tanggal])
}

model TodoItem {
  id         String        @id @default(uuid())
  karyawanId String
  judul      String
  deskripsi  String?
  deadline   DateTime?     @db.Date
  status     StatusTodo    @default(TODO)
  prioritas  PrioritasTodo @default(SEDANG)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  karyawan   User          @relation("TodoKaryawan", fields: [karyawanId], references: [id])
}

enum Role {
  SUPER_ADMIN
  KARYAWAN
  ADMIN_KANTOR
}

enum JenisAbsenKantor {
  MASUK
  PULANG
}

enum StatusSesiKantor {
  AKTIF
  SELESAI
}

enum StatusAbsensiKantor {
  HADIR
  TERLAMBAT
  ALPHA
  IZIN
  SAKIT
}

enum MetodeAbsensiKantor {
  LINK_PERSONAL
  MANUAL_ADMIN
  PENGAJUAN_KARYAWAN
}

enum JenisPengajuanIzin {
  IZIN
  SAKIT
  KLARIFIKASI_ABSEN
}

enum StatusPengajuan {
  PENDING
  DISETUJUI
  DITOLAK
}

enum PrioritasTodo {
  RENDAH
  SEDANG
  TINGGI
}

enum StatusTodo {
  TODO
  IN_PROGRESS
  DONE
}
